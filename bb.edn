{:tasks
 {lint {:doc "Run formsmith lint on src and test"
        :task (shell "clojure -M -m formsmith.main lint src test")}
  fix {:doc "Run formsmith fix on src and test"
       :task (shell "clojure -M -m formsmith.main fix src test")}
  check {:doc "Run canonical no-write check on src and test"
         :task (shell "clojure -M -m formsmith.main check src test")}
  fmt {:doc "Run formatter phase on src and test"
       :task (shell "clojure -M -m formsmith.main fmt src test")}
  analyze {:doc "Show analyzer facts for src and test"
           :task (shell "clojure -M -m formsmith.main analyze src test")}
  profiles {:doc "Show framework profiles for the framework demo"
            :task (shell "clojure -M -m formsmith.main profiles examples/framework-profile-demo/src")}
  contracts {:doc "Show LLM refactor contracts for src and test"
             :task (shell "clojure -M -m formsmith.main contracts src test")}
  verify-proofs {:doc "Verify Lean proof artifacts"
                 :task (shell "bash" "scripts/verify-proofs.sh")}
  corpus-before {:doc "Show expected findings on .before corpus fixtures"
                 :task (shell "bash" "-lc" "clojure -M -m formsmith.main lint --no-config $(find corpus -name '*.before.clj' | sort)")}
  corpus-clean {:doc "Lint .after corpus fixtures; should stay clean"
                :task (shell "bash" "-lc" "clojure -M -m formsmith.main lint --no-config --no-kondo $(find corpus -path '*/protected/*' -prune -o -name '*.after.clj' -print | sort)")}
  benchmark-v1 {:doc "Maintainer evidence packet; requires sibling nextmoon and dirty-clojure checkouts"
                :task (shell "bash" "scripts/benchmark-v1.sh")}
  validate-v1 {:doc "Maintainer evidence packet; requires sibling nextmoon and dirty-clojure checkouts"
               :task (shell "bash" "scripts/validate-v1.sh")}
  validate-cold-start {:doc "Run the repo-only cold-start validation packet in a fresh disposable workspace copy"
                       :task (shell "bash" "scripts/validate-cold-start.sh")}
  field-trial {:doc "Run pinned open-source field trials; clones public repos into target/field-trials"
               :task (shell "bash" "scripts/open-source-field-trial.sh")}
  summarize-field-trial {:doc "Summarize existing field-trial reports"
                         :task (shell "bash" "scripts/summarize-field-trial.sh")}
  verify-review-study {:doc "Verify a completed review-elimination study record; set REVIEW_STUDY=path"
                       :task (let [path (System/getenv "REVIEW_STUDY")]
                               (when-not path
                                 (throw (ex-info "Set REVIEW_STUDY=docs/review-studies/<record>.md" {})))
                               (shell "bash" "scripts/verify-review-study.sh" path))}
  test {:doc "Run tests"
        :task (shell "clojure -M:test")}
  ci {:doc "Run the local CI set"
      :depends [test check lint corpus-clean verify-proofs]}}}
